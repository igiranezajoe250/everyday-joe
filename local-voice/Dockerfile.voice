# Full agent container: Go agent + Python ASR/TTS (Whisper + Kokoro).
# Larger and heavier than service/Dockerfile (the chat-only image). Use this when
# testers need the microphone (voice in/out), not just text chat.
#
# Build from the local-voice/ directory so both service/ and scripts/ are in
# context:  docker build -f Dockerfile.voice -t everyday-agent-voice .
#
# RESOURCES: Whisper-small + Torch (CPU) need ~3-4 GB RAM. This will OOM on tiny
# instances (e.g. Render starter). Run it on a >=4 GB host, or a GPU box for
# real-time latency. Models download on first request into HF_HOME.

# ── Go build ──────────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS gobuild
WORKDIR /src
COPY service/go.mod ./
RUN go mod download
COPY service/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/agent .

# ── Python runtime ────────────────────────────────────────────────────────────
FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
      ffmpeg espeak-ng ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# CPU-only torch first (avoids the multi-GB CUDA build), then the rest.
RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY --from=gobuild /out/agent /app/agent
COPY scripts/ /app/scripts/

# Point the Go service at the bundled Python + scripts; cache models under /app.
ENV VOICE_PYTHON=python3 \
    KOKORO_TRANSCRIBE_SCRIPT=/app/scripts/transcribe_kokoro.py \
    KOKORO_SYNTHESIZE_SCRIPT=/app/scripts/synthesize_kokoro.py \
    UMUGANDA_TRANSCRIBE_SCRIPT=/app/scripts/transcribe_umuganda.py \
    KOKORO_ASR_MODEL=openai/whisper-small.en \
    HF_HOME=/app/hf-cache \
    VOICE_TEMP_DIR=/app/tmp \
    VOICE_SERVICE_ADDR=0.0.0.0:8787

EXPOSE 8787
CMD ["/app/agent"]
