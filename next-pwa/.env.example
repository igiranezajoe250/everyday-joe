# ── Client (browser Supabase SDK) ─────────────────────────────────────────
# Exposed to the browser via NEXT_PUBLIC_*. Safe; anon key is gated by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://eovubrcjtclkcuzvmzbk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server (Next API services: /api/shop, /api/save, /api/pay, /api/plan,
#                            /api/listen, /api/commute, /api/activity,
#                            /api/ucp, /api/x402, /api/bounty) ──
# Same URL + anon key, but read server-side so routes can call Supabase
# with the caller's forwarded JWT (RLS enforces per-user scope).
SUPABASE_URL=https://eovubrcjtclkcuzvmzbk.supabase.co
SUPABASE_ANON_KEY=

# ── Service-role operations (REQUIRED in production) ───────────────────────
# Wallet settlement routes such as /api/pay, /api/ucp, and /api/x402 use the
# service role for atomic transfers / checkout settlement while still resolving
# the caller from their JWT. Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional daily cron /api/cron/interest runs the 8% accrual + monthly payout +
# auto-deposit schedules. It has no user JWT, so it also needs the service role
# and a shared secret. Vercel Cron sends "Authorization: Bearer $CRON_SECRET".
# Shared secret. Vercel Cron sends "Authorization: Bearer $CRON_SECRET".
# The endpoint fails closed if this is unset, so set it before going live.
CRON_SECRET=

# Bounty model chain for /api/bounty:
# 1. Google AI Studio primary, 2. Qwen fallback, 3. Gemma fallback.
# Keep these server-side only.
GOOGLE_AI_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash
GOOGLE_GEMMA_MODEL=gemma-3-4b-it

# Qwen fallback through any OpenAI-compatible endpoint, such as vLLM/TGI.
QWEN_OPENAI_BASE_URL=
QWEN_OPENAI_MODEL=Qwen/Qwen3-8B
QWEN_OPENAI_KEY=sk-local

# Optional Gemma fallback through an OpenAI-compatible endpoint. If unset,
# /api/bounty tries GOOGLE_GEMMA_MODEL through Google AI Studio instead.
GEMMA_OPENAI_BASE_URL=
GEMMA_OPENAI_MODEL=google/gemma-3-4b-it
GEMMA_OPENAI_KEY=sk-local

# Optional hosted Bounty agent. When set, this proxy is tried before the direct
# model chain. When unset, /api/bounty calls the model chain above directly.
BOUNTY_AGENT_URL=

# ── Bounty / Save AI (local-voice service) ─────────────────────────────────
# PRIMARY: self-hosted Qwen on a GPU box via an OpenAI-compatible API (vLLM/TGI).
# LLM_OPENAI_BASE_URL=https://gpu-box.your-domain.com/v1
# LLM_OPENAI_MODEL=Qwen/Qwen3-8B
# LLM_OPENAI_KEY=sk-...   # any non-empty token for plain vLLM; real one behind a gateway

# LOCAL DEV: Ollama running Qwen (defaults work when Ollama is up).
# BOUNTY_LLM_URL=http://127.0.0.1:11434/api/chat
# BOUNTY_LLM_MODEL=qwen3:8b

# FALLBACK: Google AI Studio → Gemma 3 4B. Used only if neither the GPU box
# nor Ollama answer. Free key: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# Section agent tool calls — base URL of the Next.js API.
# In local dev this defaults to http://localhost:3000 automatically.
# In production set this to your Vercel deployment URL.
# EVERYDAY_API_BASE=https://your-app.vercel.app

# CORS allow-list for the agent service (Render). Comma-separated origins of
# your deployed frontend. localhost dev origins are always allowed.
# ALLOWED_ORIGINS=https://your-app.vercel.app
# Render injects $PORT automatically; the service binds 0.0.0.0:$PORT in prod.

# Frontend → agent service URL. The deployed frontend reaches the Render agent
# by opening the app once with ?voiceBase=https://everyday-agent.onrender.com
# (it persists to localStorage). No build-time env needed for the static legacy app.
