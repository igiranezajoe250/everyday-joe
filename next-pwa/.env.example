# ── Client (browser Supabase SDK) ─────────────────────────────────────────
# Exposed to the browser via NEXT_PUBLIC_*. Safe; anon key is gated by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://eovubrcjtclkcuzvmzbk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server (Go microservices: /api/shop, /api/save, /api/pay, /api/plan,
#                              /api/listen, /api/commute, /api/bounty) ──
# Same URL + key, but read server-side so the functions can call Supabase
# REST with the caller's forwarded JWT (RLS enforces per-user scope).
# Falls back to the NEXT_PUBLIC_* values if these are unset, but setting
# them explicitly makes intent clear in the Vercel dashboard.
SUPABASE_URL=https://eovubrcjtclkcuzvmzbk.supabase.co
SUPABASE_ANON_KEY=

# Optional. Only set if you add admin endpoints that must bypass RLS
# (e.g. seeding catalog data, server-side cron). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Bounty AI (local-voice service) ────────────────────────────────────────
# Online path: Google AI Studio → Gemma 3 4B (gemma-3-4b-it).
# Get a free key at https://aistudio.google.com/apikey
# When set, takes priority over Ollama. Leave blank to use Ollama locally.
GOOGLE_AI_KEY=

# Local path: Ollama endpoint + model (defaults work when Ollama is running).
# BOUNTY_LLM_URL=http://127.0.0.1:11434/api/chat
# BOUNTY_LLM_MODEL=gemma3:4b

# Section agent tool calls — base URL of the Next.js API.
# In local dev this defaults to http://localhost:3000 automatically.
# In production set this to your Vercel deployment URL.
# EVERYDAY_API_BASE=https://your-app.vercel.app
